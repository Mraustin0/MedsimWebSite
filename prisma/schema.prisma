generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(cuid())
  name        String
  email       String           @unique
  role        Role             @default(STUDENT)
  avatarUrl   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  specialty   String?
  university  String?          @default("Khon Kaen University")
  yearOfStudy String?
  scenarios   ScenarioRecord[]
  sessions    Session[]
}

model ScenarioRecord {
  id             String   @id @default(cuid())
  name           String
  age            Int
  gender         String
  chiefComplaint String
  description    String   @default("")
  difficulty     String   @default("medium")
  systemPrompt   String
  tags           String[]
  createdById    String
  createdAt      DateTime @default(now())
  createdBy      User     @relation(fields: [createdById], references: [id])
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  scenarioId      String
  durationSeconds Int?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  feedback        Feedback?
  messages        Message[]
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      MsgRole
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Feedback {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  scoreOnset        Int
  scoreLocation     Int
  scoreDuration     Int
  scoreCharacter    Int
  scoreAggravating  Int
  scoreRelieving    Int
  scoreTiming       Int
  scoreSeverity     Int
  scoreOverall      Int
  good              String[]
  missed            String[]
  tips              String[]
  totalQuestions    Int
  oldcartsCompleted Int
  createdAt         DateTime @default(now())
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  INSTRUCTOR
}

enum MsgRole {
  USER
  ASSISTANT
}
